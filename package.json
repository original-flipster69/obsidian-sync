    "esbuild": "^0.24.0",
    "obsidian": "^1.7.2",
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1000.0",
    "@smithy/types": "^4.13.0"
  }
}
