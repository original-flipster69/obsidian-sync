{
  "name": "obsidian-ovh-sync",
  "version": "1.0.0",
  "description": "Bidirectional sync for Obsidian vaults with OVH Cloud Object Storage",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production"
  },
